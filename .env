# ─── Apache Log Statistical Reporter — Configuration ─────────────────────────
#
# Edit the values below to match your setup.
# CLI flags (--log, --db, --format) always override these values.

# Path to the Apache log file to analyse
LOG_FILE=./data/apache_log.txt

# Path to the MaxMind GeoLite2-Country binary database (.mmdb)
GEOIP_DB=./data/GeoLite2-Country.mmdb

# Output format: text | json | csv
OUTPUT_FORMAT=text
